root = true

[*]
charset = utf-8
insert_final_newline = true
end_of_line = lf
indent_style = space
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = tab
tab_width = 8

[Makefile]
indent_style = tab
indent_size = tab
tab_width = 8

[*.yaml]
indent_size = 2

[*.yml]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
